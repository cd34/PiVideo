# Optional — for local development and CI builds only.
#
# For normal deployments, leave this file absent. Flash the image with
# Raspberry Pi Imager and use the "OS Customisation" dialog to set
# hostname, username/password, WiFi, and SSH.
#
# To use: copy to config.env and fill in your values.
# config.env is gitignored — credentials are never committed.

# Hostname — Pi will be reachable at http://<HOSTNAME>.local:8080
HOSTNAME=pivideo

# Admin account
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# WiFi
WIFI_COUNTRY=US
WIFI_SSID=MyNetwork
WIFI_PASSWORD=mypassword
